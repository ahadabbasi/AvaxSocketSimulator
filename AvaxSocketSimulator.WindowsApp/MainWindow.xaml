<Window x:Class="AvaxSocketSimulator.WindowsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvaxSocketSimulator.WindowsApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="0.15*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label
                    Grid.Column="0"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    FontSize="20" 
                    Content="Data Type"/>
                <TextBox 
                    Grid.Column="1" 
                    VerticalAlignment="Center" 
                    Padding="10 5" 
                    Text="{Binding Path=DataType, Mode=TwoWay}" 
                    IsReadOnly="{Binding Path=IsProcessing, Mode=TwoWay}"/>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label 
                    Grid.Column="0" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    FontSize="20" 
                    Content="Lock time"/>
                <TextBox 
                    Grid.Column="1" 
                    VerticalAlignment="Center" 
                    Padding="10 5" 
                    Text="{Binding Path=DelayTime, Mode=TwoWay}" 
                    IsReadOnly="{Binding Path=IsProcessing, Mode=TwoWay}"/>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label 
                    Grid.Column="0" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    FontSize="20" 
                    Content="Web Server"/>
                <TextBox
                    Grid.Column="1" 
                    VerticalAlignment="Center" 
                    Padding="10 5" 
                    Text="{Binding Path=WebServerAddress, Mode=TwoWay}" 
                    IsReadOnly="{Binding Path=IsProcessing, Mode=TwoWay}" />
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="0.25*" />
            </Grid.ColumnDefinitions>
            <Button 
                Grid.Column="1"
                Content="Start to Send" 
                FontSize="16" 
                Padding="5" 
                Name="SendButton" 
                Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>
